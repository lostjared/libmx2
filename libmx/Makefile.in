sharedstatedir = @sharedstatedir@
srcdir = @srcdir@
sysconfdir = @sysconfdir@
target_alias = @target_alias@
top_build_prefix = @top_build_prefix@
top_builddir = @top_builddir@
top_srcdir = @top_srcdir@
ACLOCAL_AMFLAGS = -I m4
AM_CPPFLAGS = \
	-I$(srcdir)/libmx \
	-I$(srcdir)/libmx/include \
	-I$(srcdir)/volk \
	-I$(builddir) \
	$(SDL2_CFLAGS) \
	$(SDL2_TTF_CFLAGS) \
	$(PNG_CFLAGS) \
	$(ZLIB_CFLAGS) \
	$(SDL2_MIXER_CFLAGS) \
	$(GL_CFLAGS) \
	$(GLM_CFLAGS) \
	$(VULKAN_CFLAGS) \
	$(JPEG_CFLAGS) \
	$(OPENCV_CFLAGS) \
	$(GL_DEFINES) \
	$(VK_DEFINES)

AM_CXXFLAGS = $(CXX20_CXXFLAGS) $(OPT_CXXFLAGS) -Wall -fPIC
AM_CFLAGS = $(OPT_CFLAGS) -Wall -fPIC
lib_LTLIBRARIES = libmx.la $(am__append_7) $(am__append_9) \
	$(am__append_11) $(am__append_13)
mx2includedir = $(includedir)/mx2
mx2gladdir = $(includedir)/mx2/glad
mx2khrdir = $(includedir)/mx2/KHR
mx2volkdir = $(includedir)/mx2/volk
pkgconfigdir = $(libdir)/pkgconfig
pkgconfig_DATA = libmx.pc $(am__append_1) $(am__append_2) \
	$(am__append_3) $(am__append_4)
EXTRA_DIST = \
	libmx.pc.in \
	libmxgl.pc.in \
	libmxvk.pc.in \
	libmxgl_cv.pc.in \
	libmxvk_cv.pc.in

libmx_la_SOURCES = \
	libmx/mx.cpp \
	libmx/util.cpp \
	libmx/loadpng.cpp \
	libmx/font.cpp \
	libmx/cfg.cpp \
	libmx/texture.cpp \
	libmx/exception.cpp \
	libmx/joystick.cpp \
	libmx/jpeg.cpp \
	libmx/input.cpp \
	libmx/sound.cpp \
	libmx/tee_stream.cpp

libmx_la_LIBADD = $(SDL2_LIBS) $(SDL2_TTF_LIBS) $(PNG_LIBS) \
	$(ZLIB_LIBS) $(PTHREAD_LIBS) $(am__append_5) $(am__append_6)
libmx_la_LDFLAGS = -version-info 1:14:0 -no-undefined
mx2include_HEADERS = libmx/mx.hpp libmx/argz.hpp libmx/util.hpp \
	libmx/jpeg.hpp libmx/loadpng.hpp libmx/object.hpp \
	libmx/font.hpp libmx/cfg.hpp libmx/tee_stream.hpp \
	libmx/texture.hpp libmx/exception.hpp libmx/joystick.hpp \
	libmx/wrapper.hpp libmx/input.hpp libmx/sound.hpp \
	$(am__append_8) $(am__append_10) $(am__append_12) \
	$(am__append_14)
@ENABLE_OPENGL_TRUE@libmxgl_la_SOURCES = \
@ENABLE_OPENGL_TRUE@	libmx/gl.cpp \
@ENABLE_OPENGL_TRUE@	libmx/model.cpp \
@ENABLE_OPENGL_TRUE@	libmx/console.cpp \
@ENABLE_OPENGL_TRUE@	libmx/src/glad.c

@ENABLE_OPENGL_TRUE@libmxgl_la_CPPFLAGS = $(AM_CPPFLAGS) -DWITH_GL
@ENABLE_OPENGL_TRUE@libmxgl_la_CXXFLAGS = $(AM_CXXFLAGS)
@ENABLE_OPENGL_TRUE@libmxgl_la_CFLAGS = $(AM_CFLAGS)
@ENABLE_OPENGL_TRUE@libmxgl_la_LIBADD = \
@ENABLE_OPENGL_TRUE@	libmx.la \
@ENABLE_OPENGL_TRUE@	$(GL_LIBS)

@ENABLE_OPENGL_TRUE@libmxgl_la_LDFLAGS = -version-info 1:14:0 -no-undefined
@ENABLE_OPENGL_TRUE@mx2glad_HEADERS = libmx/include/glad/glad.h
@ENABLE_OPENGL_TRUE@mx2khr_HEADERS = libmx/include/KHR/khrplatform.h
@ENABLE_VULKAN_TRUE@libvolk_la_SOURCES = volk/volk.cpp
@ENABLE_VULKAN_TRUE@libvolk_la_CPPFLAGS = $(AM_CPPFLAGS) -I$(srcdir)/volk -DWITH_VK
@ENABLE_VULKAN_TRUE@libvolk_la_CXXFLAGS = $(AM_CXXFLAGS)
@ENABLE_VULKAN_TRUE@libvolk_la_LIBADD = $(DL_LIBS)
@ENABLE_VULKAN_TRUE@libvolk_la_LDFLAGS = -static
@ENABLE_VULKAN_TRUE@mx2volk_HEADERS = volk/volk.h
@ENABLE_VULKAN_TRUE@libmxvk_la_SOURCES = \
@ENABLE_VULKAN_TRUE@	libmx/vk.cpp \
@ENABLE_VULKAN_TRUE@	libmx/vk_model.cpp \
@ENABLE_VULKAN_TRUE@	libmx/vk_text.cpp \
@ENABLE_VULKAN_TRUE@	libmx/vk_sprite.cpp

@ENABLE_VULKAN_TRUE@libmxvk_la_CPPFLAGS = $(AM_CPPFLAGS) -DWITH_VK
@ENABLE_VULKAN_TRUE@libmxvk_la_CXXFLAGS = $(AM_CXXFLAGS)
@ENABLE_VULKAN_TRUE@libmxvk_la_LIBADD = \
@ENABLE_VULKAN_TRUE@	libmx.la \
@ENABLE_VULKAN_TRUE@	libvolk.la \
@ENABLE_VULKAN_TRUE@	$(VULKAN_LIBS)

@ENABLE_VULKAN_TRUE@libmxvk_la_LDFLAGS = -static
@ENABLE_OPENCV_TRUE@@ENABLE_OPENGL_TRUE@libmxgl_cv_la_SOURCES = libmx/gl_cv.cpp
@ENABLE_OPENCV_TRUE@@ENABLE_OPENGL_TRUE@libmxgl_cv_la_CPPFLAGS = $(AM_CPPFLAGS) -DWITH_GL
@ENABLE_OPENCV_TRUE@@ENABLE_OPENGL_TRUE@libmxgl_cv_la_CXXFLAGS = $(AM_CXXFLAGS)
@ENABLE_OPENCV_TRUE@@ENABLE_OPENGL_TRUE@libmxgl_cv_la_LIBADD = \
@ENABLE_OPENCV_TRUE@@ENABLE_OPENGL_TRUE@	libmxgl.la \
@ENABLE_OPENCV_TRUE@@ENABLE_OPENGL_TRUE@	$(OPENCV_LIBS)

@ENABLE_OPENCV_TRUE@@ENABLE_OPENGL_TRUE@libmxgl_cv_la_LDFLAGS = -version-info 1:14:0 -no-undefined
@ENABLE_OPENCV_TRUE@@ENABLE_VULKAN_TRUE@libmxvk_cv_la_SOURCES = libmx/vk_cv.cpp
@ENABLE_OPENCV_TRUE@@ENABLE_VULKAN_TRUE@libmxvk_cv_la_CPPFLAGS = $(AM_CPPFLAGS) -DWITH_VK
@ENABLE_OPENCV_TRUE@@ENABLE_VULKAN_TRUE@libmxvk_cv_la_CXXFLAGS = $(AM_CXXFLAGS)
@ENABLE_OPENCV_TRUE@@ENABLE_VULKAN_TRUE@libmxvk_cv_la_LIBADD = \
@ENABLE_OPENCV_TRUE@@ENABLE_VULKAN_TRUE@	libmxvk.la \
@ENABLE_OPENCV_TRUE@@ENABLE_VULKAN_TRUE@	$(OPENCV_LIBS)

@ENABLE_OPENCV_TRUE@@ENABLE_VULKAN_TRUE@libmxvk_cv_la_LDFLAGS = -version-info 1:14:0 -no-undefined
