DATA = $(pkgconfig_DATA)
am__mx2glad_HEADERS_DIST = libmx/include/glad/glad.h
am__mx2include_HEADERS_DIST = libmx/mx.hpp libmx/argz.hpp \
	libmx/util.hpp libmx/jpeg.hpp libmx/loadpng.hpp \
	libmx/object.hpp libmx/font.hpp libmx/cfg.hpp \
	libmx/tee_stream.hpp libmx/texture.hpp libmx/exception.hpp \
