	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_HEADER) $$files '$(DESTDIR)$(mx2gladdir)'"; \
	  $(INSTALL_HEADER) $$files "$(DESTDIR)$(mx2gladdir)" || exit $$?; \
	done

